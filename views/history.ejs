<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GitGuard AI - Review History</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="stylesheet" href="/css/gitguard-dashboard.css">
</head>
<body class="dashboard-page">
    <main class="dashboard-shell">
        <%- include('partials/navigation', { activePage: 'history' }) %>

        <section class="hero-panel glass-panel reveal" style="--delay: 100ms;">
            <div class="hero-grid">
                <div class="hero-copy">
                    <p class="section-kicker">Archived reviews</p>
                    <h2 class="hero-title">AI review history, rendered as a premium scrollable record.</h2>
                    <p class="hero-description">
                        This page keeps the same visual language as the dashboard so the review archive feels like part of the same control surface rather than a separate admin table.
                    </p>
                </div>

                <div class="hero-copy">
                    <div class="metric-grid">
                        <%- include('partials/metric-card', { label: 'Stored reviews', value: reviews.length, detail: 'Historical AI responses from pull request analysis.' }) %>
                        <%- include('partials/metric-card', { label: 'Latest cadence', value: reviews.length ? 'Live' : 'Idle', detail: 'Whether the archive currently has recent entries.' }) %>
                        <%- include('partials/metric-card', { label: 'Format', value: 'Markdown', detail: 'Technical review output in a monospace surface.' }) %>
                        <%- include('partials/metric-card', { label: 'Viewport', value: 'Scrollable', detail: 'Optimized for dense review scanning.' }) %>
                    </div>
                </div>
            </div>
        </section>

        <section class="glass-panel history-section reveal" style="--delay: 200ms;">
            <div class="section-heading">
                <div>
                    <p class="section-kicker">Audit trail</p>
                    <h3 class="section-title">Review history</h3>
                </div>
                <span class="badge"><%= reviews.length %> entries</span>
            </div>

            <div class="history-grid">
                <% if (reviews.length) { %>
                    <% reviews.forEach(review => { %>
                        <article class="history-card glass-panel">
                            <div class="history-topline">
                                <div class="history-body">
                                    <span class="subtle-label"><%= review.repo_full_name %></span>
                                    <h4 class="history-title">PR #<%= review.pr_number %> <%= review.pr_title ? `· ${review.pr_title}` : '' %></h4>
                                </div>
                                <div class="history-avatar"><%= (review.reviewer || 'AI').slice(0, 2).toUpperCase() %></div>
                            </div>

                            <div class="history-meta">
                                <span class="badge archived"><%= review.reviewer %></span>
                                <span class="badge"><%= new Date(review.timestamp).toLocaleString() %></span>
                            </div>

                            <div class="history-surface">
                                <pre><%= review.llm_response || 'No review content stored.' %></pre>
                            </div>
                        </article>
                    <% }) %>
                <% } else { %>
                    <div class="empty-state">
                        <p class="empty-state-text">No reviews yet. Open a pull request to see the archive populate with markdown output.</p>
                    </div>
                <% } %>
            </div>
        </section>
    </main>
</body>
</html>